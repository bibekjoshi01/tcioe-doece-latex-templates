\PYG{k+kn}{from}\PYG{+w}{ }\PYG{n+nn}{scipy}\PYG{n+nn}{.}\PYG{n+nn}{signal}\PYG{+w}{ }\PYG{k+kn}{import} \PYG{n}{hilbert}

\PYG{c+c1}{\PYGZsh{} Sampling Parameters}
\PYG{n}{Fs} \PYG{o}{=} \PYG{l+m+mi}{10000}                  \PYG{c+c1}{\PYGZsh{} Sampling frequency (Hz)}
\PYG{n}{T} \PYG{o}{=} \PYG{l+m+mf}{0.1}                     \PYG{c+c1}{\PYGZsh{} Duration of signal (s)}
\PYG{n}{t} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{arange}\PYG{p}{(}\PYG{l+m+mi}{0}\PYG{p}{,} \PYG{n}{T}\PYG{p}{,} \PYG{l+m+mi}{1}\PYG{o}{/}\PYG{n}{Fs}\PYG{p}{)}   \PYG{c+c1}{\PYGZsh{} Time vector}

\PYG{c+c1}{\PYGZsh{} Message Signal (Baseband)}
\PYG{n}{Am} \PYG{o}{=} \PYG{l+m+mi}{1}                      \PYG{c+c1}{\PYGZsh{} Message amplitude}
\PYG{n}{fm} \PYG{o}{=} \PYG{l+m+mi}{50}                     \PYG{c+c1}{\PYGZsh{} Message frequency}
\PYG{n}{m\PYGZus{}t} \PYG{o}{=} \PYG{n}{Am} \PYG{o}{*} \PYG{n}{np}\PYG{o}{.}\PYG{n}{sin}\PYG{p}{(}\PYG{l+m+mi}{2} \PYG{o}{*} \PYG{n}{np}\PYG{o}{.}\PYG{n}{pi} \PYG{o}{*} \PYG{n}{fm} \PYG{o}{*} \PYG{n}{t}\PYG{p}{)}  \PYG{c+c1}{\PYGZsh{} Baseband signal}

\PYG{c+c1}{\PYGZsh{} Carrier Signal}
\PYG{n}{fc} \PYG{o}{=} \PYG{l+m+mi}{1000}                    \PYG{c+c1}{\PYGZsh{} Carrier frequency}
\PYG{n}{c\PYGZus{}cos} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{cos}\PYG{p}{(}\PYG{l+m+mi}{2} \PYG{o}{*} \PYG{n}{np}\PYG{o}{.}\PYG{n}{pi} \PYG{o}{*} \PYG{n}{fc} \PYG{o}{*} \PYG{n}{t}\PYG{p}{)}    \PYG{c+c1}{\PYGZsh{} In\PYGZhy{}phase carrier}
\PYG{n}{c\PYGZus{}sin} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{sin}\PYG{p}{(}\PYG{l+m+mi}{2} \PYG{o}{*} \PYG{n}{np}\PYG{o}{.}\PYG{n}{pi} \PYG{o}{*} \PYG{n}{fc} \PYG{o}{*} \PYG{n}{t}\PYG{p}{)}    \PYG{c+c1}{\PYGZsh{} (90° phase shift)}

\PYG{c+c1}{\PYGZsh{} Hilbert Transform of Message}
\PYG{n}{m\PYGZus{}hilbert} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{imag}\PYG{p}{(}\PYG{n}{hilbert}\PYG{p}{(}\PYG{n}{m\PYGZus{}t}\PYG{p}{)}\PYG{p}{)}

\PYG{c+c1}{\PYGZsh{} Upper Sideband (USB)}
\PYG{n}{s\PYGZus{}usb} \PYG{o}{=} \PYG{n}{m\PYGZus{}t} \PYG{o}{*} \PYG{n}{c\PYGZus{}cos} \PYG{o}{\PYGZhy{}} \PYG{n}{m\PYGZus{}hilbert} \PYG{o}{*} \PYG{n}{c\PYGZus{}sin}

\PYG{c+c1}{\PYGZsh{} Lower Sideband (LSB)}
